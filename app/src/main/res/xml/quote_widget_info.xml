<?xml version="1.0" encoding="utf-8"?>
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_description"
    android:minWidth="110dp"
    android:minHeight="80dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="350dp"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/widget_preview" />
<!--
    updatePeriodMillis="0" → Android no dispara actualizaciones automáticas.
    Todas las actualizaciones las gestiona WorkManager (UpdateQuoteWidgetWorker).
    targetCellWidth/Height → API 31+. minWidth/minHeight para API < 31.
    Tamaños físicos aproximados por breakpoint:
      Small  → 2×1 celdas  (~110×80dp)   solo quote
      Medium → 3×2 celdas  (~180×120dp)  quote + author
      Large  → 4×3 celdas  (~250×180dp)  quote + author + anime
-->
